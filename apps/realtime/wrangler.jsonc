{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "drawing-games-realtime",
	"main": "src/index.ts",
	"compatibility_date": "2026-07-10",
	"durable_objects": {
		"bindings": [
			{
				"name": "GAME_ROOM",
				"class_name": "GameRoom",
			},
		],
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["GameRoom"],
		},
	],
	"observability": {
		"enabled": true,
	},
	"upload_source_maps": true,
}
