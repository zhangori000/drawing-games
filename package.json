{
  "name": "drawing-games",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "turbo run build",
    "boundaries": "turbo boundaries",
    "check": "pnpm format:check && pnpm boundaries && turbo run lint typecheck test build && pnpm typecheck:e2e",
    "check:all": "pnpm check && pnpm test:e2e && pnpm test:e2e:mobile",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:mobile": "PLAYWRIGHT_MOBILE=1 playwright test --project=mobile-chromium --project=mobile-webkit",
    "test:integration": "pnpm --filter @drawing-games/realtime test",
    "test:simulation": "pnpm --filter @drawing-games/game-core exec vitest run src/simulation.test.ts",
    "test:unit": "pnpm --filter './packages/*' test",
    "typecheck": "turbo run typecheck",
    "typecheck:e2e": "tsc -p e2e/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "prettier": "^3.6.2",
    "turbo": "^2.10.4",
    "typescript": "^5.9.3"
  }
}
